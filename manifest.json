{
  "manifest_version": 3,
  "name": "ClipStyle",
  "version": "1.0",
  "description": "Capture and save UI elements from any webpage",

  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png"
    }
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],

  "web_accessible_resources": [
    {
      "resources": ["preview/preview.html", "preview/preview.css", "preview/preview.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
